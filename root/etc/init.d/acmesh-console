#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

: "${ACMESH_CONSOLE_LIB_DIR:=/usr/libexec/acmesh-console/lib}"
: "${ACMESH_RUNTIME_DIR:=/var/run/acmesh-console}"
: "${ACMESH_LOG_DIR:=/var/log/acmesh-console}"

acmesh_task_private_dir_upgrade() (
	dir="${1:-}"
	[ -n "$dir" ] && [ "$dir" != / ] || return 2
	if acmesh_private_dir "$dir"; then
		return 0
	fi
	[ -d "$dir" ] && [ ! -L "$dir" ] || return 1
	listing="$(LC_ALL=C ls -ld "$dir" 2>/dev/null)" || return 1
	set -- $listing
	[ "${1:-}" = drwxr-xr-x ] || return 1
	set -- $(LC_ALL=C ls -nd "$dir" 2>/dev/null) || return 1
	[ "${3:-}" = 0 ] || return 1
	chmod 700 "$dir" || return 1
	acmesh_private_dir_is_secure "$dir"
)

start_service() {
	. "$ACMESH_CONSOLE_LIB_DIR/io.sh" || return 1
	. "$ACMESH_CONSOLE_LIB_DIR/task.sh" || return 1
	for dir in \
		"$ACMESH_RUNTIME_DIR" \
		"$ACMESH_RUNTIME_DIR/requests" \
		"$ACMESH_RUNTIME_DIR/challenges" \
		"$ACMESH_RUNTIME_DIR/pending-import" \
		"$ACMESH_LOG_DIR"; do
		acmesh_private_dir "$dir" || return 1
	done
	acmesh_task_private_dir_upgrade "$ACMESH_TASK_STATE_DIR" || return 1
	acmesh_task_private_dir_upgrade "$ACMESH_TASK_LOG_DIR" || return 1
	acmesh_task_recover_interrupted || return 1
	acmesh_task_prune 200 || return 1
}
