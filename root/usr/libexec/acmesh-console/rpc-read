#!/bin/sh
set -eu

LIB_DIR="${ACMESH_LIB_DIR:-/usr/libexec/acmesh-console/lib}"
. "$LIB_DIR/json.sh"

ACMESHCTL="${ACMESHCTL:-/usr/libexec/acmesh-console/acmeshctl}"
method="${1:-}"
shift || true

unsupported_argument() {
	printf '{"ok":false,"error":"unsupported argument"}\n'
	exit 2
}

task_id_argument() {
	[ "$#" = 1 ] || unsupported_argument
	printf '%s\n' "$1" | grep -Eq '^[0-9]{14}-[0-9]+$' || {
		printf '{"ok":false,"error":"invalid task id"}\n'
		exit 2
	}
}

case "$method" in
	status)
		[ "$#" = 0 ] || unsupported_argument
		"$ACMESHCTL" status
		;;
	providers)
		[ "$#" = 0 ] || unsupported_argument
		"$ACMESHCTL" providers
		;;
	core_status)
		[ "$#" = 0 ] || unsupported_argument
		"$ACMESHCTL" core-status
		;;
	task_status)
		task_id_argument "$@"
		"$ACMESHCTL" task-status --task-id "$1"
		;;
	task_log)
		task_id_argument "$@"
		if log="$("$ACMESHCTL" task-log --task-id "$1")"; then
			printf '{"ok":true,"log":"%s"}\n' "$(acmesh_json_escape "$log")"
		else
			rc=$?
			printf '{"ok":false,"error":"%s"}\n' "$(acmesh_json_escape "$log")"
			exit "$rc"
		fi
		;;
	task_list)
		limit="${1:-50}"
		[ "$#" -le 1 ] || unsupported_argument
		case "$limit" in ''|*[!0-9]*) unsupported_argument ;; esac
		"$ACMESHCTL" task-list --limit "$limit"
		;;
	authorization_list)
		[ "$#" = 0 ] || unsupported_argument
		"$ACMESHCTL" authorization-list
		;;
	*)
		printf '{"ok":false,"error":"unsupported method"}\n'
		exit 2
		;;
esac
