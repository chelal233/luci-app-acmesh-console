#!/bin/sh
set -eu

cli_private_request() {
	cli_tmp="$(umask 077; mktemp "${TMPDIR:-/tmp}/acmesh-cli-request.XXXXXX")" || exit 1
	chmod 600 "$cli_tmp" || { rm -f "$cli_tmp"; exit 1; }
	trap 'rm -f "$cli_tmp"' HUP INT TERM EXIT
}

case "${1:-}" in
	--acknowledge-risk|--remember-authorization)
		cli_flag="$1" cli_challenge="${2:-}"
		[ "$#" = 2 ] && printf '%s\n' "$cli_challenge" | grep -Eq '^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$' || {
			printf '{"ok":false,"error":"invalid authorization challenge"}\n'
			exit 2
		}
		cli_private_request
		cli_decision=once; [ "$cli_flag" = --acknowledge-risk ] || cli_decision=remember
		printf '{"challengeId":"%s","decision":"%s"}\n' "$cli_challenge" "$cli_decision" > "$cli_tmp"
		set +e
		cli_output="$("$0" authorization-execute --request-file "$cli_tmp")"
		cli_rc=$?
		set -e
		if [ -n "$cli_output" ]; then printf '%s\n' "$cli_output"; else printf '{"ok":false,"error":"authorization challenge unavailable"}\n'; fi
		exit "$cli_rc"
		;;
esac

if [ "${2:-}" = --request-stdin ]; then
	[ "$#" = 2 ] || {
		printf '{"ok":false,"error":"--request-stdin cannot be combined with request arguments"}\n'
		exit 2
	}
	cli_command="$1"
	shift 2
	cli_private_request
	cat > "$cli_tmp" || exit 1
	"$0" "$cli_command" --request-file "$cli_tmp"
	exit $?
fi

for cli_arg in "$@"; do
	case "$cli_arg" in
		--credential|--credential=*|--key-pem|--key-pem=*|--fullchain-pem|--fullchain-pem=*|--json|--json=*)
			printf '{"ok":false,"error":"sensitive request arguments are unsupported; use --request-stdin"}\n'
			exit 2
			;;
	esac
done

ACMESH_LIB_DIR="${ACMESH_LIB_DIR:-/usr/libexec/acmesh-console/lib}"
export ACMESH_LIB_DIR
LIB_DIR="$ACMESH_LIB_DIR"
. "$LIB_DIR/cert.sh"
. "$LIB_DIR/task.sh"
. "$LIB_DIR/command.sh"
. "$LIB_DIR/dns.sh"
. "$LIB_DIR/provider.sh"
. "$LIB_DIR/deploy.sh"
. "$LIB_DIR/ssh.sh"
. "$LIB_DIR/config.sh"
. "$LIB_DIR/request_payload.sh"
. "$LIB_DIR/authorization.sh"
. "$LIB_DIR/operation.sh"

cmd="${1:-}"
shift || true

home="$(acmesh_config_string acmeHome /etc/acme)"
request_file=""
while [ "$#" -gt 0 ]; do
	case "$1" in
		--home)
			[ "$#" -ge 2 ] || { printf '{"ok":false,"error":"--home requires a value"}\n'; exit 2; }
			home="$2"
			shift 2
			;;
		--request-file)
			[ "$#" -ge 2 ] || { printf '{"ok":false,"error":"--request-file requires a value"}\n'; exit 2; }
			request_file="$2"
			shift 2
			;;
		*)
			break
			;;
	esac
done
export ACMESH_ACME_HOME="$home"

if [ -n "$request_file" ]; then
	acmesh_request_payload_validate "$request_file" || exit $?
fi

load_deploy_request() {
	deploy_type="$(acmesh_request_value "$request_file" type "$deploy_type")"
	cert_source="$(acmesh_request_value "$request_file" certSource "$cert_source")"
	domain="$(acmesh_request_value "$request_file" domain "$domain")"
	key_type="$(acmesh_request_value "$request_file" keyType "$key_type")"
	key_file="$(acmesh_request_value "$request_file" keyFile "$key_file")"
	fullchain_file="$(acmesh_request_value "$request_file" fullchainFile "$fullchain_file")"
	cert_file="$(acmesh_request_value "$request_file" certFile "$cert_file")"
	ca_file="$(acmesh_request_value "$request_file" caFile "$ca_file")"
	reloadcmd="$(acmesh_request_value "$request_file" reloadcmd "$reloadcmd")"
	source_key_file="$(acmesh_request_value "$request_file" sourceKeyFile "$source_key_file")"
	source_fullchain_file="$(acmesh_request_value "$request_file" sourceFullchainFile "$source_fullchain_file")"
	key_pem="$(acmesh_request_value "$request_file" keyPem "$key_pem")"
	fullchain_pem="$(acmesh_request_value "$request_file" fullchainPem "$fullchain_pem")"
	host="$(acmesh_request_value "$request_file" host "$host")"
	port="$(acmesh_request_value "$request_file" port "$port")"
	user="$(acmesh_request_value "$request_file" user "$user")"
	ssh_key="$(acmesh_request_value "$request_file" sshKey "$ssh_key")"
	allow_key_convert="$(acmesh_request_value "$request_file" allowKeyConvert "$allow_key_convert")"
}

load_issue_request() {
	main_domain="$(acmesh_request_value "$request_file" domain "$main_domain")"
	key_type="$(acmesh_request_value "$request_file" keyType "$key_type")"
	validation_method="$(acmesh_request_value "$request_file" validationMethod "$validation_method")"
	dns_api="$(acmesh_request_value "$request_file" dnsApi "$dns_api")"
	ca="$(acmesh_request_value "$request_file" ca "$ca")"
	webroot="$(acmesh_request_value "$request_file" webroot "$webroot")"
	listen_port="$(acmesh_request_value "$request_file" listenPort "$listen_port")"
	account_email="$(acmesh_request_value "$request_file" accountEmail "$account_email")"
	test_mode="$(acmesh_request_value "$request_file" testMode "$test_mode")"
	credentials="$(acmesh_request_lines "$request_file" credentials)"
}

acmesh_run_issue_profile() (
	profile_id="$1" resolved_file="$2" profile_home="$3"
	acmesh_profile_install_cleanup_traps "$resolved_file"
	if [ "${ACMESH_OPERATION_USE_RESOLVED:-0}" != 1 ]; then acmesh_profile_resolve_issue "$profile_id" "$resolved_file" || return 1; fi
	acmesh_profile_load_issue_file "$resolved_file" || return 1
	log_credentials="$(acmesh_redact_credentials "$ACMESH_PROFILE_CREDENTIALS")"
	command="$(acmesh_build_issue_command "$profile_home" "$ACMESH_PROFILE_DOMAIN" "$ACMESH_PROFILE_KEY_TYPE" "$ACMESH_PROFILE_VALIDATION" "$ACMESH_PROFILE_DNS_API" "$ACMESH_PROFILE_WEBROOT" "$ACMESH_PROFILE_LISTEN_PORT" "$log_credentials" "$ACMESH_PROFILE_CA" "$ACMESH_PROFILE_ACCOUNT_EMAIL" "$ACMESH_PROFILE_DOMAINS" "$ACMESH_PROFILE_CHALLENGE_ALIAS" "$ACMESH_PROFILE_DNS_SLEEP")"
	if [ "$ACMESH_PROFILE_TEST_MODE" = true ]; then
		printf '%s\n%s\n' 'TEST MODE: generated acme.sh command, but no real ACME request was sent.' "$(acmesh_mask_secret "$command")"
	else
		acmesh_execute_issue "$profile_home" "$ACMESH_PROFILE_DOMAIN" "$ACMESH_PROFILE_KEY_TYPE" "$ACMESH_PROFILE_VALIDATION" "$ACMESH_PROFILE_DNS_API" "$ACMESH_PROFILE_WEBROOT" "$ACMESH_PROFILE_LISTEN_PORT" "$ACMESH_PROFILE_CREDENTIALS" "$ACMESH_PROFILE_CA" "$ACMESH_PROFILE_ACCOUNT_EMAIL" "$ACMESH_PROFILE_DOMAINS" "$ACMESH_PROFILE_CHALLENGE_ALIAS" "$ACMESH_PROFILE_DNS_SLEEP" || return $?
		deploy_id="$(jsonfilter -i "$resolved_file" -e '@.deployProfileId' 2>/dev/null || true)"
		if [ -n "$deploy_id" ]; then
			script="$(acmesh_find_script "$profile_home")" || return 1
			ACMESH_DEPLOY_PROFILE_ID="$deploy_id" "$script" --home "$profile_home" --deploy -d "$ACMESH_PROFILE_DOMAIN" --deploy-hook acmesh-console-ssh
		fi
	fi
)

acmesh_run_deploy_profile() (
	profile_id="$1" resolved_file="$2"
	acmesh_profile_install_cleanup_traps "$resolved_file"
	if [ "${ACMESH_OPERATION_USE_RESOLVED:-0}" != 1 ]; then acmesh_profile_resolve_deploy "$profile_id" "$resolved_file" || return 1; fi
	acmesh_profile_load_deploy_file "$resolved_file" || return 1
	acmesh_execute_profile_deploy "$ACMESH_DEPLOY_TYPE" "$ACMESH_DEPLOY_CERT_SOURCE" "$ACMESH_DEPLOY_DOMAIN" \
		"$ACMESH_DEPLOY_KEY_FILE" "$ACMESH_DEPLOY_CHAIN_FILE" "$ACMESH_DEPLOY_CERT_FILE" "$ACMESH_DEPLOY_CA_FILE" "$ACMESH_DEPLOY_RELOAD" \
		"$ACMESH_DEPLOY_SOURCE_KEY" "$ACMESH_DEPLOY_SOURCE_CHAIN" "$ACMESH_DEPLOY_KEY_PEM" "$ACMESH_DEPLOY_CHAIN_PEM" \
		"$ACMESH_DEPLOY_HOST" "$ACMESH_DEPLOY_PORT" "$ACMESH_DEPLOY_USER" "$ACMESH_DEPLOY_SSH_KEY" "$ACMESH_DEPLOY_KEY_TYPE" \
		"$ACMESH_DEPLOY_SUDO_MODE" "$ACMESH_DEPLOY_OWNER" "$ACMESH_DEPLOY_GROUP" "$ACMESH_DEPLOY_MODE"
)

case "$cmd" in
	status)
		acmesh_scan_home "$home"
		;;
	providers)
		acmesh_providers_json
		;;
	config-get)
		acmesh_config_get
		;;
	config-save)
		[ -n "$request_file" ] || { printf '{"ok":false,"error":"config-save requires --request-file"}\n'; exit 2; }
		acmesh_config_save_file "$request_file"
		;;
	task-status)
		task_id=""
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--task-id) task_id="$2"; shift 2 ;;
				*) shift ;;
			esac
		done
		acmesh_task_status "$task_id"
		;;
	task-log)
		task_id=""
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--task-id) task_id="$2"; shift 2 ;;
				*) shift ;;
			esac
		done
		acmesh_task_log "$task_id"
		;;
	task-list)
		limit="50"
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--limit) limit="$2"; shift 2 ;;
				*) shift ;;
			esac
		done
		acmesh_task_list "$limit"
		;;
	renew)
		main_domain=""
		key_type=""
		test_mode=false
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--domain) main_domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			main_domain="$(acmesh_request_value "$request_file" domain "$main_domain")"
			key_type="$(acmesh_request_value "$request_file" keyType "$key_type")"
			test_mode="$(acmesh_request_value "$request_file" testMode "$test_mode")"
		fi
		if [ -z "$main_domain" ]; then
			printf '{"ok":false,"error":"domain is required"}\n'
			exit 1
		fi
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"command":"%s"}\n' "$(acmesh_json_escape "$(acmesh_build_renew_command "$home" "$main_domain" "$key_type")")"
		else
			if acmesh_key_type_is_ecc "$key_type"; then renew_subject="ecc.$main_domain"; else renew_subject="rsa.$main_domain"; fi
			acmesh_operation_start renew certificate "$renew_subject" "$request_file"
		fi
		;;
	import-history)
		task_id="$(acmesh_task_create import-history)"
		acmesh_task_run "$task_id" import-history scan acmesh_import_history "$home"
		printf '{"ok":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		;;
	import-preview)
		[ -n "$request_file" ] || { printf '{"ok":false,"error":"request required"}\n'; exit 2; }
		acmesh_config_import_preview "$request_file"
		;;
	import-apply)
		preview_id="$(acmesh_request_value "$request_file" previewId '')"
		acmesh_operation_start import-apply pendingImport "$preview_id" "$request_file"
		;;
	ssh-key)
		sub="${1:-}"
		case "$sub" in
			ensure)
				acmesh_ssh_key_ensure
				;;
			*)
				printf '{"ok":false,"error":"unsupported ssh-key command"}\n'
				exit 2
				;;
		esac
		;;
	ssh-key-ensure)
		acmesh_ssh_key_ensure
		;;
	ssh-test)
		host=""
		port="22"
		user="root"
		key=""
		remote_command="true"
		test_mode=0
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--host) host="$2"; shift 2 ;;
				--port) port="$2"; shift 2 ;;
				--user) user="$2"; shift 2 ;;
				--key) key="$2"; shift 2 ;;
				--command) remote_command="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				*) shift ;;
			esac
		done
		task_id="$(acmesh_task_create ssh-test)"
		(
			acmesh_task_run "$task_id" ssh-test connect acmesh_ssh_test_log "$host" "$port" "$user" "$key" "$remote_command" "$test_mode"
		) &
		if [ "$test_mode" = 1 ]; then
			printf '{"ok":true,"testMode":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		else
			printf '{"ok":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		fi
		;;
	core-status)
		acmesh_core_status_json "$home"
		;;
	core-install)
		email="$(acmesh_config_string defaultAccountEmail "")"
		tag="$(acmesh_config_string coreTag "${ACMESH_CORE_TAG:-v3.1.4}")"
		test_mode=false
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--email) email="$2"; shift 2 ;;
				--tag) tag="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			home="$(acmesh_request_value "$request_file" home "$home")"
			email="$(acmesh_request_value "$request_file" email "$email")"
			tag="$(acmesh_request_value "$request_file" tag "$tag")"
			test_mode="$(acmesh_request_value "$request_file" testMode "$test_mode")"
			export ACMESH_ACME_HOME="$home"
		fi
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"command":"%s"}\n' "$(acmesh_json_escape "$(acmesh_core_install_command "$home" "$email" "$tag")")"
		else
			config_home="$(acmesh_config_string acmeHome /etc/acme)" config_email="$(acmesh_config_string defaultAccountEmail '')" config_tag="$(acmesh_config_string coreTag "${ACMESH_CORE_TAG:-v3.1.4}")"
			[ "$home" = "$config_home" ] && [ "$email" = "$config_email" ] && [ "$tag" = "$config_tag" ] || { printf '{"ok":false,"error":"real core install parameters must match saved configuration"}\n'; exit 2; }
			acmesh_operation_start core-install global core "$request_file"
		fi
		;;
	core-upgrade)
		tag="$(acmesh_config_string coreTag "${ACMESH_CORE_TAG:-v3.1.4}")"
		test_mode=false
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--tag) tag="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			home="$(acmesh_request_value "$request_file" home "$home")"
			tag="$(acmesh_request_value "$request_file" tag "$tag")"
			test_mode="$(acmesh_request_value "$request_file" testMode "$test_mode")"
			export ACMESH_ACME_HOME="$home"
		fi
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"command":"%s"}\n' "$(acmesh_json_escape "$(acmesh_core_upgrade_command "$home" "$tag")")"
		else
			config_home="$(acmesh_config_string acmeHome /etc/acme)" config_tag="$(acmesh_config_string coreTag "${ACMESH_CORE_TAG:-v3.1.4}")"
			[ "$home" = "$config_home" ] && [ "$tag" = "$config_tag" ] || { printf '{"ok":false,"error":"real core upgrade parameters must match saved configuration"}\n'; exit 2; }
			acmesh_operation_start core-upgrade global core "$request_file"
		fi
		;;
	deploy-preview)
		deploy_type="local"
		cert_source="managed-acme"
		domain=""
		key_file=""
		fullchain_file=""
		cert_file=""
		ca_file=""
		reloadcmd=""
		source_key_file=""
		source_fullchain_file=""
		key_pem=""
		fullchain_pem=""
		host=""
		port="22"
		user="root"
		ssh_key="/etc/acmesh-console/ssh/id_ed25519"
		key_type=""
		allow_key_convert=0
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--type) deploy_type="$2"; shift 2 ;;
				--cert-source) cert_source="$2"; shift 2 ;;
				--domain) domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--key-file) key_file="$2"; shift 2 ;;
				--fullchain-file) fullchain_file="$2"; shift 2 ;;
				--cert-file) cert_file="$2"; shift 2 ;;
				--ca-file) ca_file="$2"; shift 2 ;;
				--reloadcmd) reloadcmd="$2"; shift 2 ;;
				--source-key-file) source_key_file="$2"; shift 2 ;;
				--source-fullchain-file) source_fullchain_file="$2"; shift 2 ;;
				--host) host="$2"; shift 2 ;;
				--port) port="$2"; shift 2 ;;
				--user) user="$2"; shift 2 ;;
				--ssh-key) ssh_key="$2"; shift 2 ;;
				*) shift ;;
			esac
			done
		[ -z "$request_file" ] || load_deploy_request
		acmesh_deploy_preview_json "$deploy_type" "$cert_source" "$domain" "$key_file" "$fullchain_file" "$cert_file" "$ca_file" "$reloadcmd" "$source_key_file" "$source_fullchain_file" "$key_pem" "$fullchain_pem" "$host" "$port" "$user" "$ssh_key" "$key_type"
		;;
	deploy-test)
		deploy_type="local"
		cert_source="managed-acme"
		domain=""
		key_file=""
		fullchain_file=""
		cert_file=""
		ca_file=""
		reloadcmd=""
		source_key_file=""
		source_fullchain_file=""
		key_pem=""
		fullchain_pem=""
		host=""
		port="22"
		user="root"
		ssh_key="/etc/acmesh-console/ssh/id_ed25519"
		key_type=""
		allow_key_convert=0
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--type) deploy_type="$2"; shift 2 ;;
				--cert-source) cert_source="$2"; shift 2 ;;
				--domain) domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--key-file) key_file="$2"; shift 2 ;;
				--fullchain-file) fullchain_file="$2"; shift 2 ;;
				--cert-file) cert_file="$2"; shift 2 ;;
				--ca-file) ca_file="$2"; shift 2 ;;
				--reloadcmd) reloadcmd="$2"; shift 2 ;;
				--source-key-file) source_key_file="$2"; shift 2 ;;
				--source-fullchain-file) source_fullchain_file="$2"; shift 2 ;;
				--host) host="$2"; shift 2 ;;
				--port) port="$2"; shift 2 ;;
				--user) user="$2"; shift 2 ;;
				--ssh-key) ssh_key="$2"; shift 2 ;;
				*) shift ;;
			esac
		done
		[ -z "$request_file" ] || load_deploy_request
		case "$deploy_type" in local|ssh) ;; *) printf '{"ok":false,"error":"unsupported deploy type"}\n'; exit 2 ;; esac
		case "$cert_source" in managed-acme|local-files|paste-pem) ;; *) printf '{"ok":false,"error":"unsupported certificate source"}\n'; exit 2 ;; esac
		[ -n "$domain" ] || { printf '{"ok":false,"error":"domain is required"}\n'; exit 2; }
		printf '{"ok":true,"testMode":true,"preview":"validated; no task or external mutation created"}\n'
		;;
	deploy-run)
		profile_id=""
		deploy_type="local"
		cert_source="managed-acme"
		domain=""
		key_file=""
		fullchain_file=""
		cert_file=""
		ca_file=""
		reloadcmd=""
		source_key_file=""
		source_fullchain_file=""
		key_pem=""
		fullchain_pem=""
		host=""
		port="22"
		user="root"
		ssh_key="/etc/acmesh-console/ssh/id_ed25519"
		key_type=""
		allow_key_convert=0
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--profile-id) profile_id="$2"; shift 2 ;;
				--type) deploy_type="$2"; shift 2 ;;
				--cert-source) cert_source="$2"; shift 2 ;;
				--domain) domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--key-file) key_file="$2"; shift 2 ;;
				--fullchain-file) fullchain_file="$2"; shift 2 ;;
				--cert-file) cert_file="$2"; shift 2 ;;
				--ca-file) ca_file="$2"; shift 2 ;;
				--reloadcmd) reloadcmd="$2"; shift 2 ;;
				--source-key-file) source_key_file="$2"; shift 2 ;;
				--source-fullchain-file) source_fullchain_file="$2"; shift 2 ;;
				--host) host="$2"; shift 2 ;;
				--port) port="$2"; shift 2 ;;
				--user) user="$2"; shift 2 ;;
				--ssh-key) ssh_key="$2"; shift 2 ;;
				--allow-key-convert) allow_key_convert=1; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			profile_id="$(acmesh_request_value "$request_file" profileId "$profile_id")"
			[ -n "$profile_id" ] || load_deploy_request
		fi
		if [ -n "$profile_id" ]; then
			acmesh_profile_validate_id "$profile_id" || { printf '{"ok":false,"error":"invalid deploy profile id"}\n'; exit 2; }
			acmesh_operation_start deploy-run deployProfile "$profile_id" "$request_file"
			exit 0
		fi
		printf '{"ok":false,"error":"real deploy requires profileId"}\n'; exit 2
		;;
	dns-test)
		main_domain=""
		dns_api="dns_cf"
		credentials=""
		test_mode=false
		profile_id=""
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--domain) main_domain="$2"; shift 2 ;;
				--dns-api) dns_api="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			profile_id="$(acmesh_request_value "$request_file" profileId '')"
			main_domain="$(acmesh_request_value "$request_file" domain "$main_domain")"
			dns_api="$(acmesh_request_value "$request_file" dnsApi "$dns_api")"
			test_mode="$(acmesh_request_value "$request_file" testMode "$test_mode")"
			credentials="$(acmesh_request_lines "$request_file" credentials)"
		fi
		task_id="$(acmesh_task_create dns-test)"
		if [ -n "$profile_id" ]; then
			acmesh_profile_validate_id "$profile_id" || { printf '{"ok":false,"error":"invalid issue profile id"}\n'; exit 2; }
			dns_workspace="$(acmesh_task_workspace "$task_id")"; dns_resolved="$dns_workspace/issue-profile.json"
			acmesh_profile_resolve_issue "$profile_id" "$dns_resolved" && acmesh_profile_load_issue_file "$dns_resolved" || { rm -f "$dns_resolved"; exit 1; }
			main_domain="$ACMESH_PROFILE_DOMAIN" dns_api="$ACMESH_PROFILE_DNS_API" credentials="$ACMESH_PROFILE_CREDENTIALS" test_mode="$ACMESH_PROFILE_TEST_MODE"
			rm -f "$dns_resolved"
		fi
		credentials="$(acmesh_sanitize_credentials "$credentials")" || { printf '{"ok":false,"error":"invalid DNS credential payload"}\n'; exit 2; }
		(
			acmesh_task_run "$task_id" dns-test diagnostic acmesh_dns_test_log "$main_domain" "$dns_api" "$credentials" "$test_mode"
		) &
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		else
			printf '{"ok":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		fi
		;;
	preview-issue)
		main_domain=""
		key_type="ec256"
		validation_method="dns"
		dns_api="dns_cf"
		webroot=""
		listen_port=""
		credentials=""
		ca="letsencrypt"
		account_email="$(acmesh_config_string defaultAccountEmail "")"
		test_mode=false
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--domain) main_domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--validation-method) validation_method="$2"; shift 2 ;;
				--dns-api) dns_api="$2"; shift 2 ;;
				--ca) ca="$2"; shift 2 ;;
				--webroot) webroot="$2"; shift 2 ;;
				--listen-port) listen_port="$2"; shift 2 ;;
				--account-email) account_email="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
			done
		[ -z "$request_file" ] || load_issue_request
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			command="$(acmesh_build_issue_command "$home" "$main_domain" "$key_type" "$validation_method" "$dns_api" "$webroot" "$listen_port" "$credentials" "$ca" "$account_email")"
			printf '{"ok":true,"testMode":true,"command":"%s","note":"%s"}\n' \
				"$(acmesh_json_escape "$(acmesh_mask_secret "$command")")" \
				"$(acmesh_json_escape "TEST MODE: no real ACME request will be sent; the task will be marked successful.")"
		else
			[ -n "$account_email" ] || { printf '{"ok":false,"error":"account email is required for real mode"}\n'; exit 1; }
			acmesh_issue_preview_json "$home" "$main_domain" "$key_type" "$validation_method" "$dns_api" "$webroot" "$listen_port" "$credentials" "$ca" "$account_email"
		fi
		;;
	issue)
		profile_id=""
		main_domain=""
		key_type="ec256"
		validation_method="dns"
		dns_api="dns_cf"
		webroot=""
		listen_port=""
		credentials=""
		ca="letsencrypt"
		account_email="$(acmesh_config_string defaultAccountEmail "")"
		test_mode=false
		while [ "$#" -gt 0 ]; do
			case "$1" in
				--profile-id) profile_id="$2"; shift 2 ;;
				--domain) main_domain="$2"; shift 2 ;;
				--key-type) key_type="$2"; shift 2 ;;
				--validation-method) validation_method="$2"; shift 2 ;;
				--dns-api) dns_api="$2"; shift 2 ;;
				--ca) ca="$2"; shift 2 ;;
				--webroot) webroot="$2"; shift 2 ;;
				--listen-port) listen_port="$2"; shift 2 ;;
				--account-email) account_email="$2"; shift 2 ;;
				--test-mode) test_mode=1; shift ;;
				--real-mode) test_mode=false; shift ;;
				*) shift ;;
			esac
		done
		if [ -n "$request_file" ]; then
			profile_id="$(acmesh_request_value "$request_file" profileId "$profile_id")"
			[ -n "$profile_id" ] || load_issue_request
		fi
		if [ -n "$profile_id" ]; then
			acmesh_profile_validate_id "$profile_id" || { printf '{"ok":false,"error":"invalid issue profile id"}\n'; exit 2; }
			workspace="${TMPDIR:-/tmp}/acmesh-issue-preview.$$"; acmesh_private_dir "$workspace" || exit 1; resolved_file="$workspace/issue-profile.json"
			acmesh_profile_resolve_issue "$profile_id" "$resolved_file" || { printf '{"ok":false,"error":"issue profile resolution failed"}\n'; exit 2; }
			acmesh_profile_load_issue_file "$resolved_file" || exit 1
			profile_test_mode="$ACMESH_PROFILE_TEST_MODE"
			if [ "$profile_test_mode" = true ]; then
				command="$(acmesh_build_issue_command "$home" "$ACMESH_PROFILE_DOMAIN" "$ACMESH_PROFILE_KEY_TYPE" "$ACMESH_PROFILE_VALIDATION" "$ACMESH_PROFILE_DNS_API" "$ACMESH_PROFILE_WEBROOT" "$ACMESH_PROFILE_LISTEN_PORT" "$(acmesh_redact_credentials "$ACMESH_PROFILE_CREDENTIALS")" "$ACMESH_PROFILE_CA" "$ACMESH_PROFILE_ACCOUNT_EMAIL" "$ACMESH_PROFILE_DOMAINS" "$ACMESH_PROFILE_CHALLENGE_ALIAS" "$ACMESH_PROFILE_DNS_SLEEP")"
				printf '{"ok":true,"testMode":true,"command":"%s"}\n' "$(acmesh_json_escape "$(acmesh_mask_secret "$command")")"
			else acmesh_operation_start issue issueProfile "$profile_id" "$request_file"; fi
			rm -rf "$workspace"
			exit 0
		fi
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"command":"%s"}\n' "$(acmesh_json_escape "$(acmesh_build_issue_command "$home" "$main_domain" "$key_type" "$validation_method" "$dns_api" "$webroot" "$listen_port" "$(acmesh_redact_credentials "$credentials")" "$ca" "$account_email")")"; exit 0
		else
			printf '{"ok":false,"error":"real issue requires profileId"}\n'; exit 2
		fi
		(
			log_credentials="$(acmesh_redact_credentials "$credentials")"
			command="$(acmesh_build_issue_command "$home" "$main_domain" "$key_type" "$validation_method" "$dns_api" "$webroot" "$listen_port" "$log_credentials" "$ca" "$account_email")"
			if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
				acmesh_task_run "$task_id" issue-test test-mode printf '%s\n%s\n' \
					"TEST MODE: generated acme.sh command, but no real ACME request was sent." \
					"$(acmesh_mask_secret "$command")"
			else
				acmesh_task_run "$task_id" issue acme-sh acmesh_execute_issue "$home" "$main_domain" "$key_type" "$validation_method" "$dns_api" "$webroot" "$listen_port" "$credentials" "$ca" "$account_email"
			fi
		) &
		if [ "$test_mode" = 1 ] || [ "$test_mode" = true ]; then
			printf '{"ok":true,"testMode":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		else
			printf '{"ok":true,"taskId":"%s"}\n' "$(acmesh_json_escape "$task_id")"
		fi
		;;
	authorization-list)
		ACMESH_AUTH_RECOMPUTE_CALLBACK=acmesh_operation_recompute
		export ACMESH_AUTH_RECOMPUTE_CALLBACK
		acmesh_auth_list
		;;
	authorization-execute)
		[ -n "$request_file" ] || { printf '{"ok":false,"error":"request required"}\n'; exit 2; }
		acmesh_operation_execute_challenge "$request_file"
		;;
	secret-export)
		scope="$(acmesh_request_value "$request_file" scope config-with-secrets)"
		[ "$scope" = config-with-secrets ] || { printf '{"ok":false,"error":"unsupported export scope"}\n'; exit 2; }
		acmesh_operation_start secret-export config current "$request_file"
		;;
	certificate-revoke|certificate-remove)
		domain="$(acmesh_request_value "$request_file" domain '')" key_type="$(acmesh_request_value "$request_file" keyType rsa)"
		acmesh_profile_domain "$domain" || { printf '{"ok":false,"error":"invalid certificate domain"}\n'; exit 2; }
		if acmesh_key_type_is_ecc "$key_type"; then subject="ecc.$domain"; else subject="rsa.$domain"; fi
		acmesh_operation_start "$cmd" certificate "$subject" "$request_file"
		;;
	profile-delete)
		profile_type="$(acmesh_request_value "$request_file" profileType '')" profile_id="$(acmesh_request_value "$request_file" profileId '')"
		case "$profile_type" in account|issue|deploy) ;; *) printf '{"ok":false,"error":"invalid profile type"}\n'; exit 2;; esac
		acmesh_profile_validate_id "$profile_id" || { printf '{"ok":false,"error":"invalid profile id"}\n'; exit 2; }
		dependencies="$(acmesh_config_profile_dependencies "$profile_type" "$profile_id")" || exit $?
		[ "$dependencies" = '[]' ] || { printf '{"ok":false,"error":"profileReferenced","dependencies":%s}\n' "$dependencies"; exit 4; }
		acmesh_operation_start profile-delete profile "$profile_type.$profile_id" "$request_file"
		;;
	authorization-revoke)
		record_id="$(acmesh_request_value "$request_file" recordId '')"
		acmesh_auth_revoke "$record_id" || { printf '{"ok":false,"error":"authorization revoke failed"}\n'; exit 2; }
		printf '{"ok":true}\n'
		;;
	authorization-revoke-all)
		acmesh_auth_revoke_all || { printf '{"ok":false,"error":"authorization revoke all failed"}\n'; exit 2; }
		printf '{"ok":true}\n'
		;;
	ssh-hostkey-probe)
		host="$(acmesh_request_value "$request_file" host '')" port="$(acmesh_request_value "$request_file" port 22)"
		challenge_id="$(date +%s)-$$"; challenge_dir="${ACMESH_SSH_CHALLENGE_DIR:-/var/run/acmesh-console/ssh-hostkey-challenges}"
		acmesh_private_dir "$challenge_dir" || exit 1
		acmesh_ssh_probe_host_key "$host" "$port" "$challenge_dir/$challenge_id"
		;;
	ssh-hostkey-confirm)
		challenge_id="$(acmesh_request_value "$request_file" challengeId '')"
		acmesh_auth_valid_id "$challenge_id" || { printf '{"ok":false,"error":"invalid host key challenge"}\n'; exit 2; }
		challenge_dir="${ACMESH_SSH_CHALLENGE_DIR:-/var/run/acmesh-console/ssh-hostkey-challenges}"
		acmesh_ssh_confirm_host_key "$challenge_dir/$challenge_id"
		;;
	*)
		printf '{"ok":false,"error":"unsupported command"}\n'
		exit 2
		;;
esac
